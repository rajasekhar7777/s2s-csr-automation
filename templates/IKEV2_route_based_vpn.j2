{# ====================================================================
   Route-based IKEv2 / IPsec VPN tunnel
   Hard-coded:  IKE version 2, route-based mode (Tunnel iface)
   Variable:    eff_wan_interface, eff_wan_gateway (from inventory)
   NOTE:        BGP (router bgp / address-family) is configured via
                separate playbook tasks with explicit parents:
                IOS does not accept multi-level nested config when
                pushed flat through ios_config src=template.
   ==================================================================== #}

{# ---------- CIDR -> dotted netmask lookup (no ipaddr dependency) ---------- #}
{%- set cidr_to_mask = {
   0:'0.0.0.0',         1:'128.0.0.0',       2:'192.0.0.0',       3:'224.0.0.0',
   4:'240.0.0.0',       5:'248.0.0.0',       6:'252.0.0.0',       7:'254.0.0.0',
   8:'255.0.0.0',       9:'255.128.0.0',    10:'255.192.0.0',    11:'255.224.0.0',
  12:'255.240.0.0',    13:'255.248.0.0',    14:'255.252.0.0',    15:'255.254.0.0',
  16:'255.255.0.0',    17:'255.255.128.0',  18:'255.255.192.0',  19:'255.255.224.0',
  20:'255.255.240.0',  21:'255.255.248.0',  22:'255.255.252.0',  23:'255.255.254.0',
  24:'255.255.255.0',  25:'255.255.255.128',26:'255.255.255.192',27:'255.255.255.224',
  28:'255.255.255.240',29:'255.255.255.248',30:'255.255.255.252',31:'255.255.255.254',
  32:'255.255.255.255'
} -%}

{# ---------- Crypto: keyring ---------- #}
crypto ikev2 keyring {{ effective_keyring_name }}
 peer {{ safe_desc }}
  address {{ remote_peer_ip }}
  pre-shared-key {{ vpn_psk }}
 exit
!

{# ---------- Crypto: IKEv2 profile ---------- #}
crypto ikev2 profile {{ effective_profile_name }}
{% if eff_match_identity_remote_type == 'address' %}
 match identity remote address {{ eff_match_identity_remote_value | default(remote_peer_ip, true) }} 255.255.255.255
{% else %}
 match identity remote fqdn {{ eff_match_identity_remote_value }}
{% endif %}
{% if (eff_identity_local_type | length) > 0 and (eff_identity_local_value | length) > 0 %}
{% if eff_identity_local_type == 'address' %}
 identity local address {{ eff_identity_local_value }}
{% else %}
 identity local fqdn {{ eff_identity_local_value }}
{% endif %}
{% endif %}
 authentication remote pre-share
 authentication local pre-share
 keyring local {{ effective_keyring_name }}
 lifetime {{ eff_ikev2_lifetime }}
 dpd 10 5 on-demand
!

{# ---------- Transform-set + IPsec profile ---------- #}
crypto ipsec transform-set AES256-SHA256 esp-aes 256 esp-sha256-hmac
 mode tunnel
!
crypto ipsec profile {{ effective_ipsec_profile_name }}
 set transform-set AES256-SHA256
 set pfs group20
 set ikev2-profile {{ effective_profile_name }}
!

{# ---------- ACL (only if user supplied entries) ---------- #}
{% if (eff_acl_lines | length) > 0 %}
ip access-list extended {{ effective_acl_name }}
{% for line in eff_acl_lines %}
 {{ loop.index * 10 }} {{ line }}
{% endfor %}
!
{% endif %}

{# ---------- Tunnel interface ---------- #}
interface Tunnel{{ tunnel_id }}
 description {{ tunnel_desc }}
 ip address {{ tunnel_local_ip }} {{ tunnel_mask | default('255.255.255.252', true) }}
 ip mtu 1400
 ip tcp adjust-mss 1360
 tunnel source {{ eff_wan_interface }}
 tunnel mode ipsec ipv4
 tunnel destination {{ remote_peer_ip }}
 tunnel protection ipsec profile {{ effective_ipsec_profile_name }}
{% if (eff_acl_lines | length) > 0 %}
 ip access-group {{ effective_acl_name }} in
{% endif %}
 no shutdown
!

{# ---------- WAN host-route to peer (named) ---------- #}
ip route {{ remote_peer_ip }} 255.255.255.255 {{ eff_wan_gateway }} name WAN_ROUTE_{{ safe_desc }}
!

{# ---------- IP SLA + track ---------- #}
ip sla {{ tunnel_id }}
 icmp-echo {{ tunnel_remote_ip }} source-interface Tunnel{{ tunnel_id }}
 frequency 10
 threshold 2000
 timeout 3000
ip sla schedule {{ tunnel_id }} life forever start-time now
!
track {{ tunnel_id }} ip sla {{ tunnel_id }} reachability
!

{# ====================================================================
   STATIC routing  ->  static routes for each local_network via Tunnel
   ==================================================================== #}
{% if eff_routing_type == 'static' and (eff_local_networks | length) > 0 %}
{% for e in eff_local_networks %}
ip route {{ e.network }} {{ e.mask }} Tunnel{{ tunnel_id }} name {{ safe_desc }}_NET{{ loop.index }}
{% endfor %}
!
{% endif %}

{# ====================================================================
   CSR_LIST prefix-list  ->  always populated from local_networks
   ==================================================================== #}
{% if (eff_local_networks | length) > 0 %}
{% for e in eff_local_networks %}
ip prefix-list {{ eff_csr_pl_name }} seq {{ (eff_pl_next_seq | int) + (loop.index0 * 5) }} permit {{ e.network }}/{{ e.bits }}{% if (eff_csr_pl_lege | length) > 0 %} {{ eff_csr_pl_lege }}{% endif %}

{% endfor %}
!
{% endif %}

{# ====================================================================
   Dynamic-only filter machinery (prefix-lists + route-maps)
   ==================================================================== #}
{% if eff_routing_type == 'dynamic' %}
{% if (inbound_prefixes | default([]) | length) > 0 %}
{% for p in inbound_prefixes %}
ip prefix-list PL_IN_T{{ tunnel_id }} seq {{ loop.index * 5 }} permit {{ p }}
{% endfor %}
route-map RM_IN_T{{ tunnel_id }} permit 10
 match ip address prefix-list PL_IN_T{{ tunnel_id }}
!
{% endif %}
{% if (outbound_prefixes | default([]) | length) > 0 %}
{% for p in outbound_prefixes %}
ip prefix-list PL_OUT_T{{ tunnel_id }} seq {{ loop.index * 5 }} permit {{ p }}
{% endfor %}
route-map RM_OUT_T{{ tunnel_id }} permit 10
 match ip address prefix-list PL_OUT_T{{ tunnel_id }}
!
{% endif %}
{% endif %}
